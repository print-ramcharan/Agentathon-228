<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Account Details"
            app:navigationIcon="@drawable/ic_close" 
            app:titleTextColor="#FFFFFF"/>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Icon -->
        <ImageView
            android:id="@+id/imgLogoLarge"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center_horizontal"
            android:src="@android:drawable/ic_menu_compass"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/textServiceName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Netflix"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/textDomainName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="netflix.com"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="40dp"/>

        <!-- Username -->
         <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Username / Email"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#333333"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:layout_marginBottom="24dp">
            
            <TextView
                android:id="@+id/detailUsername"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="user@example.com"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>
                
            <ImageView
                android:id="@+id/btnCopyUsername"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_copy"
                android:padding="8dp"
                android:tint="#00E676"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <!-- Password -->
         <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
            
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#333333"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:layout_marginBottom="32dp">
            
            <TextView
                android:id="@+id/detailPassword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="••••••••••"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:inputType="textPassword"/>
                
            <ImageView
                android:id="@+id/btnTogglePassword"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_visibility"
                android:padding="8dp"
                android:tint="#888888"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
                
             <ImageView
                android:id="@+id/btnCopyPassword"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_copy"
                android:padding="8dp"
                android:tint="#00E676"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        
        <LinearLayout
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:orientation="horizontal"
             android:gravity="center">
             
             <Button
                android:id="@+id/btnEdit"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Edit"
                android:backgroundTint="#444444"
                android:layout_marginEnd="8dp"/>
                
             <Button
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Delete"
                android:backgroundTint="#B00020"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
